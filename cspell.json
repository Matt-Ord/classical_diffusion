{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en",
    "words": [
        "axhline",
        "boltzman",
        "cmap",
        "diffeqsolve",
        "diffrax",
        "frameon",
        "Heun",
        "intertial",
        "lambdify",
        "Langevin",
        "ndindex",
        "pcolormesh",
        "pickler",
        "PRNG",
        "saveat",
        "savez",
        "sympy",
        "ttflist",
        "unnormalised",
        "Unpickler",
        "viridis",
        "visualizable",
        "vmap",
        "vmax",
        "vmin",
        "xedges",
        "xlim",
        "yedges",
        "ylim",
        "yscale"
    ],
    "ignoreWords": [
        "Phonopy",
        "Wannier",
        "pytest",
        "pydata",
        "pylint",
        "pydocstyle",
        "numpy",
        "isort",
        "ndarray",
        "xlabel",
        "ylabel",
        "pyproject",
        "scipy",
        "trange",
        "tqdm",
        "jrandom",
        "srepr"
    ],
    "flagWords": [
        "hte",
        "teh"
    ],
    "allowCompoundWords": true,
    "maxNumberOfProblems": 1000,
    "useGitignore": true,
    "ignorePaths": [
        "cspell.json",
        "*.bat",
        ".gitignore"
    ],
    "noConfigSearch": true
}
