{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en",
    "words": [
        "axhline",
        "boltzman",
        "cmap",
        "diffeqsolve",
        "diffrax",
        "frameon",
        "Heun",
        "lambdify",
        "Langevin",
        "pcolormesh",
        "pickler",
        "PRNG",
        "saveat",
        "savez",
        "sympy",
        "ttflist",
        "unnormalised",
        "Unpickler",
        "viridis",
        "visualizable",
        "vmap",
        "xedges",
        "xlim",
        "yedges",
        "ylim",
        "yscale"
    ],
    "ignoreWords": [
        "Phonopy",
        "Wannier",
        "pytest",
        "pydata",
        "pylint",
        "pydocstyle",
        "numpy",
        "isort",
        "ndarray",
        "xlabel",
        "ylabel",
        "pyproject",
        "scipy",
        "trange",
        "tqdm",
        "jrandom"
    ],
    "flagWords": [
        "hte",
        "teh"
    ],
    "allowCompoundWords": true,
    "maxNumberOfProblems": 1000,
    "ignorePaths": [
        "*.snap",
        "node_modules",
        "__snapshots__",
        "package-lock.json",
        "coverage/**",
        "dist/**",
        "dist.*/**",
        "temp/**",
        "CHANGELOG.md",
        "package.json",
        ".cspell.json",
        "cspell.json",
        ".vscode/**",
        ".devcontainer/**",
        ".github/**",
        ".pytest_cache/**",
        ".ruff_cache/**",
        ".venv/**",
        ".vscode/**",
        "build/**",
        "docs/**",
        "*.egg-info/**"
    ],
    "noConfigSearch": true
}
